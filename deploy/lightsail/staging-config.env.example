# Lightsail staging deployment inputs
# Copy to deploy/lightsail/staging-config.env and fill in actual values.

REPO_URL=git@github.com:YOUR-ORG/YOUR-REPO.git
REPO_REF=main
DOMAIN=staging.example.com
CERTBOT_EMAIL=ops@example.com

APP_NAME=youth-together
APP_USER=youthtogether
APP_GROUP=youthtogether
APP_DIR=/opt/youth-together
ENV_FILE=/etc/youth-together.env

# Optional infrastructure notes for rollout tracking
LIGHTSAIL_INSTANCE_NAME=
LIGHTSAIL_STATIC_IP_NAME=
SSH_HOST=
SSH_USER=ubuntu

# Bootstrap runs first. Set ENABLE_HTTPS=1 after DNS is already pointing at the server.
ENABLE_HTTPS=0
